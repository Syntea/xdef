<?xml version="1.0" encoding="UTF-8"?>
<!-- POZOR: spravna verze web-app/@version ma byt 6.1 (ne 6.0) - ale kvuli aktualni nepripravenosti IDE Eclipse (mozna i jinych) se docasne pouziva 6.0 -->
<web-app
	version="6.0"
	xmlns="https://jakarta.ee/xml/ns/jakartaee"
   	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  	xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
>
    <context-param>
        <param-name>contextDefaultEncoding</param-name>
        <param-value>UTF-8</param-value>
    </context-param>

    <servlet>
        <servlet-name>Example</servlet-name>
        <servlet-class>org.xdef.web.servlet.Example</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GenXdef</servlet-name>
        <servlet-class>org.xdef.web.servlet.GenXdef</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GenSchema</servlet-name>
        <servlet-class>org.xdef.web.servlet.GenSchema</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Derby</servlet-name>
        <servlet-class>org.xdef.web.servlet.Derby</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Service</servlet-name>
        <servlet-class>org.xdef.web.servlet.Service</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>Example</servlet-name>
        <url-pattern>/Example</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GenXdef</servlet-name>
        <url-pattern>/GenXdef</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GenSchema</servlet-name>
        <url-pattern>/GenSchema</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Derby</servlet-name>
        <url-pattern>/Derby</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Service</servlet-name>
        <url-pattern>/Service</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>