<assembly
    xmlns             ="http://maven.apache.org/ASSEMBLY/2.0.0"
    xmlns:xsi         ="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd"
>
    <id>userdoc</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <files>
        <file>
            <outputDirectory>META-INF/maven/${project.groupId}/${project.artifactId}</outputDirectory>
            <source>.flattened-pom.xml</source>
            <destName>pom.xml</destName>
        </file>
        <file>
            <outputDirectory>META-INF</outputDirectory>
            <source>changelog.md</source>
            <filtered>true</filtered>
        </file>
        <file>
            <outputDirectory>META-INF</outputDirectory>
            <source>src/main/resources-filters/org/xdef/sys/config/pominfo.properties</source>
            <filtered>true</filtered>
        </file>
    </files>
    <fileSets>
        <fileSet>
            <outputDirectory>META-INF</outputDirectory>
            <directory>..</directory>
            <includes>
                <include>README.md</include>
                <include>apache-license-2.0.md</include>
            </includes>
        </fileSet>
        <fileSet>
            <outputDirectory>documentation</outputDirectory>
            <directory>src/documentation</directory>
            <includes>
                <include>*.md</include>
                <include>*.pdf</include>
            </includes>
        </fileSet>
        <fileSet>
            <outputDirectory>.</outputDirectory>
            <directory>src/userdoc/data</directory>
        </fileSet>
        <fileSet>
            <outputDirectory>.</outputDirectory>
            <directory>src/userdoc/data-filter</directory>
            <filtered>true</filtered>
        </fileSet>
    </fileSets>
    <dependencySets>
        <dependencySet>
            <useProjectArtifact>true</useProjectArtifact>
            <useProjectAttachments>true</useProjectAttachments>
            <includes>
                <include>org.xdef:xdef</include>
            </includes>
            <outputDirectory>.</outputDirectory>
        </dependencySet>
        <dependencySet>
            <useProjectArtifact>false</useProjectArtifact>
            <scope>test</scope>
            <includes>
                <include>org.apache.derby:derby</include>
                <include>org.yaml:snakeyaml</include>
                <include>net.sf.saxon:Saxon-HE</include>
                <include>org.xmlresolver:xmlresolver</include>
            </includes>
            <outputDirectory>examples/lib</outputDirectory>
        </dependencySet>
    </dependencySets>
</assembly>
